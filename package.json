{
  "name": "seishiro",
  "version": "0.2.21-dev",
  "description": "The Centralized API Orchestrator for Modern Web Applications.",
  "type": "module",
  "main": "./cjs/index.js",
  "module": "./esm/index.js",
  "types": "./esm/index.d.ts",
  "exports": {
    ".": {
      "import": "./esm/index.js",
      "require": "./cjs/index.js",
      "types": "./esm/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "build:package": "rm -rf dist && bun format && tsc -p tsconfig.json && tsc -p tsconfig.cjs.json && bun run minifybuild && bun run postbuild",
    "postbuild": "cp package.json README.md LICENSE dist/",
    "minifybuild": "bun run ./minify.ts",
    "bun:build": "bun build ./src/**/*.ts --outdir ./dist",
    "test": "bun test",
    "lint": "biome check",
    "format": "biome format --write"
  },
  "license": "AGPL-3.0",
  "author": "Ernestoyoofi",
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.3.2",
    "@vercel/functions": "^3.4.3",
    "glob": "^13.0.6",
    "next": "^16.1.6",
    "terser": "^5.46.0",
    "typescript": "^5.9.3"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ernestoyoofi/seishiro.git"
  },
  "homepage": "https://github.com/ernestoyoofi/seishiro#readme",
  "keywords": [
    "api",
    "context",
    "seishiro"
  ],
  "bugs": {
    "url": "https://github.com/ernestoyoofi/seishiro/issues"
  }
}
